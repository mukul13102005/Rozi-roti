# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# App Configuration
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=RoziRoti by Ratna
VITE_APP_DESCRIPTION=Premium Women's Ethnic Fashion from Surat

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true
VITE_ENABLE_DARK_MODE=true

# Payment Gateway (Razorpay)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Email Configuration
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your_email@gmail.com
VITE_SMTP_PASS=your_app_password

# Admin
VITE_ADMIN_EMAIL=ratna@roziroti.com

# SEO
VITE_SITE_URL=https://roziroti.com
VITE_SITE_NAME=RoziRoti by Ratna
VITE_TWITTER_HANDLE=@roziroti

# Social Media
VITE_INSTAGRAM_URL=https://instagram.com/roziroti
VITE_FACEBOOK_URL=https://facebook.com/roziroti
VITE_PINTEREST_URL=https://pinterest.com/roziroti

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry for Error Tracking
VITE_SENTRY_DSN=your_sentry_dsn

# Rate Limiting
VITE_RATE_LIMIT_WINDOW=900000
VITE_RATE_LIMIT_MAX=100

# Cache
VITE_CACHE_TTL=300
VITE_CACHE_MAX_ITEMS=100

# Security
VITE_JWT_SECRET=your_jwt_secret
VITE_JWT_EXPIRY=7d
VITE_REFRESH_TOKEN_EXPIRY=30d

# Database (if using backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roziroti
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
